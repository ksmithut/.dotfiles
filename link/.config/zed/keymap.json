[
  {
    "context": "Terminal",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-[": "workspace::ActivatePreviousPane",
      "cmd-]": "workspace::ActivateNextPane",
      "cmd-|": "pane::SplitRight",
      "cmd-D": "pane::SplitDown",
      "cmd-d": "pane::SplitRight",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-A": "agent::OpenHistory",
    },
  },
  // Collapse entries
  {
    "context": "Editor",
    "bindings": {
      "cmd-shift-c": "project_panel::CollapseAllEntries",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "cmd-shift-c": "project_panel::CollapseAllEntries",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "shift-enter": ["terminal::SendText", "\u001b\r"],
    },
  },
]
