{
  "Custom Error Class": {
    "prefix": "custom-error",
    "body": [
      "class ${1:ErrorClassName} extends Error {",
      "  code: string",
      "  constructor (message) {",
      "    super(message)",
      "    Error.captureStackTrace(this, this.constructor)",
      "    this.code = '${2:ERROR_CODE}'",
      "  }",
      "}"
    ]
  },
  "Map Get Or Insert": {
    "prefix": "get-or-insert",
    "body": [
      "function getOrInsert<K, V>(map: Map<K, V>, key: K, defaultValue: V): V {",
      "  if (map.has(key)) return map.get(key) as V",
      "  map.set(key, defaultValue)",
      "  return defaultValue",
      "}"
    ]
  }
}
